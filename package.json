{
  "name": "chaincss",
  "version": "2.8.15",
  "description": "ChainCSS - The first CSS-in-JS library with true auto-detection mixed mode. Zero runtime by default, dynamic when you need it.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.js",
      "require": "./dist/advanced.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "require": "./dist/compiler/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./plugin/vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.js",
      "require": "./dist/plugins/vite.cjs"
    },
    "./plugin/webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "import": "./dist/plugins/webpack.js",
      "require": "./dist/plugins/webpack.cjs"
    }
  },
  "scripts": {
    "build": "npm run build:clean && npm run build:types && node scripts/build.mjs",
    "build:watch": "npm run build:clean && npm run build:types && node scripts/build.mjs --watch",
    "build:clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:core": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --external:vue --external:react --external:react-dom --external:svelte",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --format=esm --outfile=dist/cli/index.js --packages=external && printf '#!/usr/bin/env node\\n' | cat - dist/cli/index.js > dist/cli/tmp && mv dist/cli/tmp dist/cli/index.js && chmod +x dist/cli/index.js",
    "build:plugins": "esbuild src/plugins/vite.ts --bundle --platform=node --format=esm --outfile=dist/plugins/vite.js --packages=external && esbuild src/plugins/webpack.ts --bundle --platform=node --format=esm --outfile=dist/plugins/webpack.js --packages=external",
    "build:runtime": "esbuild src/runtime/index.ts --bundle --platform=browser --format=esm --outfile=dist/runtime/index.js --external:react --external:react-dom --external:vue --external:svelte --external:url",
    "build:browser": "esbuild src/browser.ts --bundle --platform=browser --format=esm --outfile=dist/browser.js --external:react --external:react-dom --external:vue --external:svelte --external:url",
    "build:compiler": "esbuild src/compiler/index.ts --bundle --platform=node --format=esm --outfile=dist/compiler/index.js --packages=external",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "CHAINCSS_TEST_VERBOSE=1 vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "bench:baseline": "node --expose-gc --import tsx benchmarks/save-baseline.js",
    "bench:check": "node --expose-gc --import tsx benchmarks/check-regression.js",
    "bench:ci": "npm run bench:check"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "csstype": "^3.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "vitest": {
    "setupFiles": [
      "./vitest.setup.ts"
    ]
  },
  "keywords": [
    "css-in-js",
    "zero-runtime",
    "atomic-css",
    "mixed-mode",
    "auto-detection",
    "react",
    "vue",
    "svelte",
    "vite",
    "webpack"
  ],
  "author": "Rommel Caneos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/melcanz08/chaincss"
  },
  "homepage": "https://chaincss.dev",
  "bugs": {
    "url": "https://github.com/melcanz08/chaincss/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "browserslist": "^4.28.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "glob": "^13.0.6"
  },
  "browser": "./dist/browser.js",
  "bin": {
    "chaincss": "./dist/cli/index.js"
  }
}
