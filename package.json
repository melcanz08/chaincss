{
  "name": "@melcanz85/chaincss",
  "version": "1.10.2",
  "description": "A simple package transpiler for js to css",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "node": {
        "require": "./node/index.js"
      },
      "browser": {
        "import": "./browser/index.js"
      },
      "default": "./browser/index.js"
    },
    "./node": {
      "types": "./types.d.ts",
      "require": "./node/index.js"
    },
    "./browser": {
      "types": "./types.d.ts",
      "import": "./browser/index.js"
    },
    "./react": {
      "types": "./types.d.ts",
      "browser": {
        "import": "./browser/index.js"
      },
      "default": "./browser/index.js"
    }
  },
  "types": "types.d.ts",
  "files": [
    "node/",
    "browser/",
    "shared/",
    "types.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melcanz08/chaincss.git"
  },
  "homepage": "https://melcanz08.github.io/chaincss-website",
  "bin": {
    "chaincss": "./node/chaincss.js"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "clean-css": "^5.3.3",
    "vm2": "^3.9.19"
  },
  "peerDependencies": {
    "autoprefixer": "^10.0.0",
    "browserslist": "^4.28.1",
    "caniuse-db": "^1.0.30001770",
    "postcss": "^8.5.6"
  },
  "peerDependenciesMeta": {
    "autoprefixer": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "browserslist": {
      "optional": true
    },
    "caniuse-db": {
      "optional": true
    }
  },
  "keywords": [
    "css",
    "js",
    "transpiler",
    "compiler",
    "css-in-js",
    "react"
  ],
  "author": "Rommel Caneos",
  "license": "MIT"
}
