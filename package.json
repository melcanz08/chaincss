{
  "name": "@melcanz85/chaincss",
  "version": "1.9.4",
  "description": "A simple package transpiler for js to css",
  "main": "index.js",
  "module": "index.react.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.react.js"
    },
    "./react": {
      "import": "./index.react.js"
    }
  },
  "types": "types.d.ts",
  "files": [
    "index.js",
    "index.react.js",
    "chaincss.js",
    "transpiler.js",
    "tokens.js",
    "react-hooks.js",
    "strVal.js",
    "atomic-optimizer.js",
    "cache-manager.js",
    "prefixer.js",
    "types.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melcanz08/chaincss.git"
  },
  "homepage": "https://melcanz08.github.io/chaincss-website",
  "bin": {
    "chaincss": "chaincss.js"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "clean-css": "^5.3.3",
    "vm2": "^3.9.19"
  },
  "peerDependencies": {
    "autoprefixer": "^10.0.0",
    "browserslist": "^4.28.1",
    "caniuse-db": "^1.0.30001770",
    "postcss": "^8.5.6"
  },
  "peerDependenciesMeta": {
    "autoprefixer": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "browserslist": {
      "optional": true
    },
    "caniuse-db": {
      "optional": true
    }
  },
  "keywords": [
    "css",
    "js",
    "transpiler",
    "compiler"
  ],
  "author": "Rommel Caneos",
  "license": "MIT"
}
